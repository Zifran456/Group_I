<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KitchenSync - Liked Recipes</title>

  <!-- Bootstrap 5 CSS -->
  <link 
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" 
    rel="stylesheet"
  >

  <!-- Bootstrap Icons -->
  <link 
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" 
    rel="stylesheet"
  >

  <!-- Our Custom CSS -->
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>

  <div class="page-wrapper">

    <!-- ========== HEADER ========== -->
    <div class="inner-header">
      <a href="/dashboard" class="back-link">
        <i class="bi bi-arrow-left"></i> Back
      </a>
      <span></span>
      <a href="/dashboard" class="home-link">
        <i class="bi bi-house-fill"></i>
      </a>
    </div>

    <!-- ========== PAGE TITLE ========== -->
    <div class="page-header mb-3">
      <h2>Liked Recipes</h2>
      <p class="text-muted">Your saved favorite recipes</p>
    </div>

    <!-- ========== SEARCH BAR ========== -->
    <div class="search-bar" style="justify-content: flex-end;">
      <div class="search-input-wrapper" style="width: 260px;">
        <input
          type="text"
          placeholder="Search liked recipes"
          class="page-search-input"
          data-target="#likedRecipeList"
          style="
            width: 100%;
            padding: 0.7rem 2.5rem 0.7rem 1rem;
            border: 1px solid var(--border-gray);
            border-radius: 8px;
            font-size: 0.9rem;
            background-color: var(--white);
          "
        >
        <span class="search-icon-inside">
          <i class="bi bi-search"></i>
        </span>
      </div>
    </div>

    <!-- ========== LIKED RECIPE LIST ========== -->
    <div class="recipe-list" id="likedRecipeList">
      <div class="recipe-grid">

        <% if (!likedRecipes || likedRecipes.length === 0) { %>
          <div class="w-100 text-center py-5">
            <i class="bi bi-heart" style="font-size: 3rem; color: #ccc;"></i>
            <h4 class="mt-3">No liked recipes yet</h4>
            <p class="text-muted">Recipes you save or like will appear here.</p>
          </div>
        <% } else { %>

          <% likedRecipes.forEach(recipe => { %>
            <div class="recipe-card searchable-item">
              <div class="recipe-card-image">
                <% if (recipe.image) { %>
                  <img 
                    src="<%= recipe.image %>" 
                    alt="<%= recipe.title %>"
                    style="width:100%; height:100%; object-fit:cover;"
                  >
                <% } else { %>
                  <i class="bi bi-image" style="font-size:2rem; color:#CCC;"></i>
                <% } %>
              </div>

              <div class="recipe-card-info">
                <h5><%= recipe.title %></h5>

                <% if (recipe.ingredients && recipe.ingredients.length > 0) { %>
                  <p><%= recipe.ingredients.slice(0, 3).join(", ") %><%= recipe.ingredients.length > 3 ? "..." : "" %></p>
                <% } else { %>
                  <p>Saved recipe</p>
                <% } %>

                <a href="/recipes/<%= recipe._id %>" class="btn-learn-more">Learn more</a>
              </div>
            </div>
          <% }) %>

        <% } %>

      </div>
      <!-- End recipe-grid -->

      <% if (likedRecipes && likedRecipes.length > 0) { %>
        <button class="btn-load-more">Load more</button>
      <% } %>

    </div>
    <!-- End Liked Recipe List -->

  </div>
  <!-- End Page Wrapper -->

  <!-- Bootstrap 5 JS -->
  <script 
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
  </script>

  <!-- Our Custom JS -->
  <script src="/js/app.js"></script>

</body>
</html>